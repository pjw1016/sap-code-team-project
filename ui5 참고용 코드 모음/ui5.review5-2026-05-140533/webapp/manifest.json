{
  "_version": "1.60.0",
  "sap.app": {
    "id": "code.t0.ui5.review5",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.23.0",
      "toolsId": "095aa063-162b-405c-a129-fce99258aa7d"
    },
    "dataSources": {
      "ZUI_JHY_CARRIER_O2_VAN": {
        "uri": "/sap/opu/odata/IWFND/CATALOGSERVICE;v=2/Annotations(TechnicalName='ZUI_JHY_CARRIER_O2_VAN',Version='0001')/$value/",
        "type": "ODataAnnotation",
        "settings": {
          "localUri": "localService/mainService/ZUI_JHY_CARRIER_O2_VAN.xml"
        }
      },
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZUI_JHY_CARRIER_O2/",
        "type": "OData",
        "settings": {
          "annotations": [
            "ZUI_JHY_CARRIER_O2_VAN"
          ],
          "localUri": "localService/mainService/metadata.xml",
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.23",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.uxap": {},
        "sap.ui.table": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "code.t0.ui5.review5.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {}
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "clearControlAggregation": true,
        "controlAggregation": "pages",
        "controlId": "idFlexibleColumnLayout",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "code.t0.ui5.review5.view",
        "async": true,
        "viewPath": "code.t0.ui5.review5.view",
        "bypassed": {
        }
      },
      "routes": [
        {
          "name": "RouteCarrier",
          "pattern": ":layout:",
          "target": [
            "TargetCarrier"
          ]
        },
        {
          "name": "RouteConnection",
          "pattern": "connection/{carrid}/{layout}",
          "target": ["TargetCarrier", "TargetConnection"]
        },
        {
          "name": "RouteFlight",
          "pattern": "flight/{carrid}/{connid}/{layout}",
          "target": ["TargetCarrier", "TargetConnection", "TargetFlight"]
        }

      ],
      "targets": {
        "TargetCarrier": {
          "id": "Carrier",
          "name": "Carrier",
          "controlAggregation": "beginColumnPages"
        },
        "TargetConnection": {
          "viewType": "XML",
          "transition": "slide",
          "viewId": "Connection",
          "viewName": "Connection",
          "controlAggregation": "midColumnPages"
        },
        "TargetFlight": {
          "viewType": "XML",
          "transition": "flip",
          "viewId": "Flight",
          "viewName": "Flight",
          "controlAggregation": "endColumnPages"
        }
      }
    },
    "rootView": {
      "viewName": "code.t0.ui5.review5.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
