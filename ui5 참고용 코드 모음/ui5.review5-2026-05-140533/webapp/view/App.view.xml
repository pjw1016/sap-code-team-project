<!--
    App.view.xml은 이 애플리케이션의 가장 바깥 화면입니다.
    실제 업무 화면을 직접 많이 그리기보다는, 여러 화면을 담을 큰 그릇을 마련하는 역할을 합니다.
-->
<mvc:View
    controllerName="code.t0.ui5.review5.controller.App"
    displayBlock="true"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
>
    <!--
        sap.m.App은 모바일과 데스크톱에서 화면 전환을 안정적으로 관리해 주는 기본 컨테이너입니다.
        이 안에 FlexibleColumnLayout을 넣어, 목록-상세-세부상세로 이어지는 Fiori식 탐색 구조를 구성합니다.
    -->
    <App id="app">
        <pages>
            <!--
                FlexibleColumnLayout은 최대 세 개의 컬럼을 나란히 보여 줄 수 있는 레이아웃입니다.
                Carrier 목록은 beginColumn, Connection 상세는 midColumn, Flight 상세는 endColumn에 배치됩니다.

                layout 속성은 config 모델의 /layout 값에 바인딩되어 있습니다.
                따라서 컨트롤러가 config>/layout 값을 바꾸면 화면의 컬럼 배치도 함께 변합니다.
            -->
            <f:FlexibleColumnLayout
                id="idFlexibleColumnLayout"
                stateChange=".onStateChanged"
                backgroundDesign="Solid"
                layout="{config>/layout}"
            />
        </pages>
    </App>
</mvc:View>
