<!--
    Connection.view.xml은 선택한 항공사의 상세 정보를 보여 주는 중간 컬럼 화면입니다.
    항공사 기본 정보와 그 항공사가 가진 연결편 목록을 함께 보여 주며, 사용자는 여기서 특정 연결편을 선택해 Flight 상세로 이동합니다.
-->
<mvc:View
    controllerName="code.t0.ui5.review5.controller.Connection"
    xmlns:core="sap.ui.core"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap"
    xmlns:form="sap.ui.layout.form"
    xmlns:f="sap.f"
>
    <!--
        ObjectPageLayout은 상세 화면을 여러 섹션으로 나누어 표현하는 데 적합한 Fiori 레이아웃입니다.
        머리말에는 핵심 식별 정보를, 본문에는 일반정보와 관련 목록을 체계적으로 배치할 수 있습니다.
    -->
    <uxap:ObjectPageLayout
        id="idObjectPageLayout"
        showTitleInHeaderContent="true"
        alwaysShowContentHeader="false"
        preserveHeaderStateOnScroll="false"
        headerContentPinnable="true"
        isChildPage="true"
        upperCaseAnchorBar="false"
    >   
        <!-- 화면이 접히거나 스크롤될 때도 사용자가 현재 항공사를 인식할 수 있도록 제목 영역을 구성합니다. -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle>
                <uxap:snappedHeading>
                    <Title
                        text="{Carrid} - {Carrname}"
                        level="H1"
                    />
                </uxap:snappedHeading>
                <uxap:actions>
                    <!-- 이 버튼들은 상세 화면에서 흔히 제공되는 작업의 자리를 보여 줍니다. 현재는 화면 구조 중심의 예제로 볼 수 있습니다. -->
                    <ToggleButton
                        text="Edit"
                        type="Emphasized"
                    />
                    <Button
                        text="Delete"
                        type="Transparent"
                    />
                    <Button
                        text="Copy"
                        type="Transparent"
                    />
                    <Button
                        icon="sap-icon://action"
                        type="Transparent"
                    />
                </uxap:actions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!--
            headerContent는 상세 화면 상단의 요약 정보입니다.
            사용자는 본문을 읽기 전에 이 영역만 보아도 어떤 항공사를 보고 있는지 빠르게 파악할 수 있습니다.
        -->
        <uxap:headerContent>
            <FlexBox
                wrap="Wrap"
                fitContainer="true"
                alignItems="Stretch"
            >
                <Avatar
                    displaySize="L"
                    displayShape="Circle"
                    class="sapUiTinyMarginEnd"
                    src="sap-icon://flight"
                >
                    <!--
                        Avatar를 클릭했을 때 더 큰 이미지를 보여 주는 LightBox입니다.
                        이미지 경로는 view 모델의 /imagePath에 바인딩되어 있습니다.
                    -->
                    <detailBox>
                        <LightBox>
                            <imageContent>
                                <LightBoxItem
                                    alt="없음"
                                    imageSrc="{view>/imagePath}"
                                    subtitle="비행기 정보"
                                    title="{Carrname} 항공사"
                                />
                            </imageContent>
                        </LightBox>
                    </detailBox>
                </Avatar>
                <!-- 아래 VBox들은 항공사 ID, 이름, 통화 코드, URL 같은 핵심 속성을 보기 좋게 묶어 보여 줍니다. -->
                <VBox
                    justifyContent="Center"
                    class="sapUiSmallMarginEnd"
                >
                    <Label text="항공사ID" />
                    <Title text="{Carrid}" />
                    <!-- {/Carr('XX')/Carrid} -->
                </VBox>
                <VBox
                    justifyContent="Center"
                    class="sapUiSmallMarginEnd"
                >
                    <Label text="항공사명" />
                    <Title text="{Carrname}" />
                </VBox>
                <VBox
                    justifyContent="Center"
                    class="sapUiSmallMarginEnd"
                >
                    <Label text="통화코드" />
                    <Title text="{Currcode}" />
                </VBox>
                <VBox
                    justifyContent="Center"
                    class="sapUiSmallMarginEnd"
                >
                    <Label text="Url" />
                    <Link
                        href="{Url}"
                        text="{Url}"
                    />
                </VBox>
            </FlexBox>
        </uxap:headerContent>

        <uxap:sections>
            <!-- 일반정보 섹션은 항공사 한 건의 주요 필드를 정돈된 form 형태로 다시 보여 줍니다. -->
            <uxap:ObjectPageSection title="일반정보">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <!--
                                SimpleForm은 Label과 Text를 짝지어 기본 정보를 읽기 좋게 배치합니다.
                                화면 크기에 따라 ResponsiveGridLayout이 적절히 열 수를 조정합니다.
                            -->
                            <form:SimpleForm
                                layout="ResponsiveGridLayout"
                                labelSpanL="4"
                                labelSpanM="4"
                                columnsL="2"
                                columnsM="2"
                            >
                                <form:content>
                                    <Label text="항공사ID" />
                                    <Text text="{Carrid}" />
                                    <Label text="항공사명" />
                                    <Text text="{Carrname}" />
                                    <Label text="통화코드" />
                                    <Text text="{Currcode}" />
                                    <Label text="URL" />
                                    <Text text="{Url}" />
                                </form:content>
                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- 항공편 정보 섹션은 현재 항공사에 연결된 Connection 목록을 보여 줍니다. -->
            <uxap:ObjectPageSection title="항공편 정보">
                <uxap:subSections>
                    <uxap:ObjectPageSubSection>
                        <uxap:blocks>
                            <!--
                                items="{path : 'to_Connection'}"는 현재 바인딩된 항공사에서 연결편 내비게이션 속성을 따라갑니다.
                                즉, Carrier 한 건의 상세 안에서 그와 연결된 Connection 목록을 바로 펼쳐 보는 구조입니다.
                            -->
                            <Table
                                id="idConnTable"
                                items="{path : 'to_Connection'}"
                            >
                                <columns>
                                    <Column>
                                        <Text text="항공편번호" />
                                    </Column>
                                </columns>
                                <items>
                                    <!-- 연결편 번호를 누르면 endColumn의 Flight 상세 화면으로 이동합니다. -->
                                    <ColumnListItem
                                        type="Navigation"
                                        press=".onListItemPress"
                                    >
                                        <cells>
                                            <ObjectIdentifier text="{Connid}" />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>
        </uxap:sections>
    </uxap:ObjectPageLayout>
</mvc:View>
