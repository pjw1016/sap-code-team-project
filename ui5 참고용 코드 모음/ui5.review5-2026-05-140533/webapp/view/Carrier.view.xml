<!--
    Carrier.view.xml은 항공사 목록을 보여 주는 첫 번째 컬럼 화면입니다.
    사용자는 이 화면에서 항공사를 검색하고 정렬한 뒤, 특정 항공사를 선택하여 연결편 상세로 이동합니다.
-->
<mvc:View
    controllerName="code.t0.ui5.review5.controller.Carrier"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
>
    <!-- <Page id="page" title="{i18n>title}">
    </Page> -->

    <!--
        DynamicPage는 제목 영역과 본문 영역을 세련되게 나누어 주는 Fiori 컨테이너입니다.
        단순 Page보다 목록 화면의 도구 모음과 표를 배치하기에 더 적합합니다.
    -->
    <f:DynamicPage
        id="idDynamicPage"
        toggleHeaderOnTitleClick="false"
    >
        <!-- 화면 상단 제목 영역입니다. i18n 모델을 사용하므로, 문구를 코드에서 분리해 관리할 수 있습니다. -->
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <Title text="{i18n>title}" />
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <!-- 본문 영역에는 검색/정렬 도구와 항공사 목록 테이블을 배치합니다. -->
        <f:content>
            <VBox fitContainer="true">
                <!--
                    OverflowToolbar는 화면 폭이 좁아질 때 버튼을 자연스럽게 숨기거나 넘겨 줍니다.
                    목록 위의 검색과 정렬처럼 보조 기능을 담기에 알맞은 도구 모음입니다.
                -->
                <OverflowToolbar class="sapFDynamicPageAlignContent">
                    <ToolbarSpacer />
                    <SearchField
                        search=".onSearch"
                        width="17.5rem"
                    />
                    <!-- <OverflowToolbarButton icon="sap-icon://add" text="Add" type="Transparent" press=".onAdd"/> -->
                    <OverflowToolbarButton
                        icon="sap-icon://sort"
                        text="Sort"
                        type="Transparent"
                        press=".onSort"
                    />
                </OverflowToolbar>

                <!--
                    CarrierSet은 manifest.json에 등록된 기본 OData 모델의 엔티티 집합입니다.
                    expand: 'to_Connection'은 항공사와 연결된 항공편 정보를 함께 읽어 오라는 뜻입니다.
                    덕분에 각 항공사의 연결편 개수를 화면에서 바로 계산할 수 있습니다.
                -->
                <Table
                    id="idCarrierTable"
                    inset="false"
                    items="{ path: '/CarrierSet', parameters: { expand: 'to_Connection' } }"
                    class="sapFDynamicPageAlignContent"
                    width="auto"
                    autoPopinMode="true"
                >
                    <!-- 표 내부 제목과 추가 버튼을 제공하는 영역입니다. -->
                    <headerToolbar>
                        <Toolbar>
                            <Title text="Carriers" />
                            <ToolbarSpacer />
                            <Button
                                icon="sap-icon://add"
                                text="Add"
                                type="Transparent"
                                press=".onAdd"
                            />
                        </Toolbar>
                    </headerToolbar>
                    <!-- 데이터가 없을 때 보여 줄 대체 콘텐츠입니다. 사용자가 새로고침을 시도할 수 있게 합니다. -->
                    <noData>
                        <Button
                            icon="sap-icon://refresh"
                            text="{i18n>refresh}"
                            type="Transparent"
                            press=".onRefresh"
                        />
                    </noData>

                    <!--
                        columns는 표의 열 구조를 정의합니다.
                        autoPopin 관련 속성은 작은 화면에서 열이 아래쪽 보조 정보로 접히도록 도와줍니다.
                    -->
                    <columns>
                        <Column demandPopin="false">
                            <Text text="Carrier" />
                        </Column>
                        <Column
                            autoPopinWidth="20"
                            popinDisplay="Inline"
                        >
                            <Text text="Currency" />
                        </Column>
                        <Column
                            autoPopinWidth="20"
                            popinDisplay="Inline"
                            hAlign="End"
                        >
                            <Text text="Url" />
                        </Column>
                    </columns>
                    <items>
                        <!--
                            ColumnListItem은 CarrierSet의 각 항공사 한 건을 표현합니다.
                            연결편이 없는 항공사는 Error 하이라이트와 Inactive 타입으로 표시하여,
                            학생들이 데이터 상태와 UI 상태가 함께 움직인다는 점을 관찰할 수 있습니다.
                        -->
                        <ColumnListItem
                            counter="{= ${to_Connection}.length }"
                            highlight="{= ${to_Connection}.length === 0 ? 'Error' : 'None' }"
                            type="{= ${to_Connection}.length === 0 ? 'Inactive' : 'Navigation' }"
                            press=".onListItemPress"
                        >
                            <cells>
                                <!-- 항공사명과 항공사 ID를 함께 보여 주는 식별 정보입니다. -->
                                <ObjectIdentifier
                                    title="{Carrname}({= ${to_Connection}.length === 0 ? '운행 중단' : ${to_Connection}.length })"
                                    text="{Carrid}"
                                />
                                <!-- 통화 코드와 URL은 항공사의 보조 속성입니다. -->
                                <Text text="{Currcode}" />
                                <Link
                                    href="{Url}"
                                    text="{Url}"
                                />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
