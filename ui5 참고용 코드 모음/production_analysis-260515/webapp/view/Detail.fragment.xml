<core:FragmentDefinition xmlns:feeds="sap.viz.ui5.controls.common.feeds" xmlns:data="sap.viz.ui5.data" xmlns:viz="sap.viz.ui5.controls" 
    xmlns:microchart="sap.suite.ui.microchart"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:uxap="sap.uxap"
    xmlns:form="sap.ui.layout.form"
    xmlns:layout="sap.ui.layout"
>
    <!-- 
        uxap : UX Application, 엔터프라이즈 상세 화면 UI를 제공하는 라이브러리
        주요 기능
         - 반응형
         - 스크롤 섹션 이동
         - Header 축소/확장
         - Section 구조화
     -->  
    <uxap:ObjectPageLayout id="idObjectPageLayout"
        showTitleInHeaderContent="true"
        alwaysShowContentHeader="false"
    >
        <!--
            Header Title
             - Expanded(Default) : Header 펼침 생태 
                - Header content 가 보여진다.
             - Snapped : Header 접음 상태
                - Header content 가 숨겨진다.
        -->
        <uxap:headerTitle>
            <uxap:ObjectPageDynamicHeaderTitle id="idObejctPageDynamicHeaderTitle">
                <uxap:expandedHeading>
                    <VBox id="idHeadingVBox"
                        alignItems="Start"
                    >
                        <Title id="idHeadingTitle" 
                            text="{detail>/ProductAgg/Maktx}"
                            wrapping="true"
                            class="sapUiResponsiveMarginEnd"
                        />
                        <Text id="idHeadingText"
                            text="{detail>/ProductAgg/Matnr}"
                            class="sapUiResponsiveMarginEnd"
                        />
                    </VBox>
                </uxap:expandedHeading>     
                <uxap:snappedHeading>
                    <!-- 
                        FlexBox : 반응형 Box
                         - 너비가 충분치 않은 경우 wrap="Wrap" 설정을 통해 들여쓰기를 해준다.
                    -->
                    <FlexBox id="idSnappedHeading"
                        wrap="Wrap"
                        alignItems="Center"
                    >
                        <Avatar id="idSnappedAvatar"
                            badgeIcon="sap-icon://product"
                            fallbackIcon="sap-icon://product"
                            class="sapUiSmallMarginEnd"
                        />
                        <Title id="idSnappedTitle"
                            text="{detail>/ProductAgg/Maktx}"
                            class="sapUiSmallMarginEnd"
                        />
                        <Text id="idSnappedText" 
                            text="{detail>/ProductAgg/Year}년 {detail>/ProductAgg/Mnth}월 {detail>/ProductAgg/Week}주차"
                            class="sapUiSmallMarginEnd"
                        />
                    </FlexBox>
                </uxap:snappedHeading>
                <uxap:navigationActions>
                    <OverflowToolbarButton id="idHeaderToolbarButton"
                        type="Transparent"
                        icon="sap-icon://decline"
                        tooltip="Close"
                        press=".onOverFlowToolbarButtonClosePress"
                    />
                </uxap:navigationActions>
            </uxap:ObjectPageDynamicHeaderTitle>
        </uxap:headerTitle>

        <!-- 
            Header content 
             - Main Page 에서 선택한 행에 대한 상세 데이터 출력
        -->
        <uxap:headerContent>
            <FlexBox id="idHeaderContentFlexBox"
                wrap="Wrap"
                fitContainer="false"
                alignItems="Stretch"
            >
                <Avatar id="idHeaderContentAvatar"
                    badgeIcon="sap-icon://product"
                    fallbackIcon="sap-icon://product"
                    class="sapUiResponsiveMargin"
                />
            
                <VBox id="idHeaderContentWerks"
                    justifyContent="Center"
                    class="sapUiResponsiveMargin"
                >
                    <Label id="idLabel20" text="플랜트번호"/>
                    <Text id="idHeaderContentTextWerks" text="{detail>/ProductAgg/Werks}"/>
                </VBox>

                <VBox id="idHeaderContentYear"
                    justifyContent="Center"
                    class="sapUiResponsiveMargin"
                >
                    <Label id="idHeaderContentLabelYear" text="연도"/>
                    <Text id="idHeaderContentTextYear" text="{detail>/ProductAgg/Year}"/>
                </VBox>
                <VBox id="idHeaderContentMnth"
                    justifyContent="Center"
                    class="sapUiResponsiveMargin"
                >
                    <Label id="idHeaderContentLabelMnth" text="월"/>
                    <Text id="idHeaderContentTextMnth" text="{detail>/ProductAgg/Mnth}"/>
                </VBox>
                <VBox id="idHeaderContentWeek"
                    justifyContent="Center"
                    class="sapUiResponsiveMargin"
                >
                    <Label id="idHeaderContentLabelWeek" text="주차"/>
                    <Text id="idHeaderContentTextWeek" text="{detail>/ProductAgg/Week}"/>
                </VBox>

                <VBox id="idHeaderContentProduction"
                    justifyContent="Center"
                    class="sapUiResponsiveMargin"
                >
                    <Label id="idLabel30" text="생산량"/>
                    <ObjectNumber id="idText30"
                        number="{detail>/ProductAgg/ActqtOut}"
                        unit="{detail>/ProductAgg/Meins}"
                    />
                </VBox>
            </FlexBox>

        </uxap:headerContent>

        <!-- 
            Section : 본문 
             - ObjectPageSection 1 : 본문 1
             - ObjectPageSection 2 : 본문 2
             - ObjectPageSection 3 : 본문 3
             - ...
        -->
        <uxap:sections>
            <!-- 본문 1. 계획 비율 분석 차트 -->
            <uxap:ObjectPageSection id="idSectionChart"
                title="계획 비율 분석 차트"
            >

                <uxap:subSections>
                    <uxap:ObjectPageSubSection id="idBarChart">
                        <uxap:blocks>
                            <form:SimpleForm id="idSimpleFormChart"
                                layout="ResponsiveGridLayout"
                            >
                                <FlexBox id="idHeaderContentFlexBoxChart"   
                                    wrap="Wrap"
                                    alignItems="Center"
                                >

                                    <VBox id="idHeaderContentVBoxBarChart"
                                        class="sapUiSmallMargin"
                                        width="40%"
                                    >
                                        <microchart:InteractiveBarChart id="idHeaderContentBarChart"
                                            class="sapUiSmallMarginEnd"
                                        >
                                            <microchart:bars>
                                                <microchart:InteractiveBarChartBar id="idBarSalesPlan"
                                                    label="판매 계획"
                                                    value="{= Number(${detail>/SalesPlan/Menge}) }"
                                                />
                                                <microchart:InteractiveBarChartBar id="idBarPIRPlan"
                                                    label="PIR 계획"
                                                    value="{= Number(${detail>/PIRPlan/Plnmg}) }"
                                                />
                                            </microchart:bars>
                                        </microchart:InteractiveBarChart>
                                    </VBox>

                                    <VBox id="idHeaderContentVBoxDonutChart"
                                        alignContent="End"
                                        class="sapUiSmallMargin"
                                        height="100px"
                                        width="auto"
                                    >
                                        <microchart:InteractiveDonutChart id="idHeaderContentDonutChart"
                                            displayedSegments="2"
                                        >
                                            <microchart:segments>
                                                <microchart:InteractiveDonutChartSegment id="idDonutSalesPlan"
                                                    label="판매 계획"
                                                    value="{= Number(${detail>/SalesPlan/Menge}) }"
                                                />
                                                <microchart:InteractiveDonutChartSegment id="idDonutPIRPlan"
                                                    label="PIR 계획"
                                                    value="{= Number(${detail>/PIRPlan/Plnmg}) }"
                                                />
                                            </microchart:segments>
                                        </microchart:InteractiveDonutChart>
                                    </VBox>

                                </FlexBox>
                            
                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>

            </uxap:ObjectPageSection>

            <!-- 본문 2. 판매 계획 상세 정보 -->
            <uxap:ObjectPageSection id="idSalesPlanDetailInfo"
                title="판매 계획 상세 정보"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection id="idTestTest">
                        <uxap:blocks>
                            <form:SimpleForm id="idtestestest"
                                layout="ResponsiveGridLayout"
                            >
                                <Label id="idLabel1" text="label1"/>
                                <Text  id="idText1"  text="text1"/>
                            
                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

            <!-- 본문 3. PIR 계획 상세 정보 -->
            <uxap:ObjectPageSection id="idPIRDetailInfoSection"
                title="PIR 계획 상세 정보"
            >
                <uxap:subSections>
                    <uxap:ObjectPageSubSection id="idPIRObjectPageSubSection">
                        <uxap:blocks>
                            <form:SimpleForm id="idPIRBlockSimpleForm"
                                layout="ResponsiveGridLayout"
                            >
                                <VBox id="idPIRInfoVBox"
                                    width="100%"
                                >
                                    <HBox id="idPIRInfoHBox"
                                        width="100%"
                                        alignItems="Start"
                                        justifyContent="SpaceBetween"
                                    >

                                        <form:SimpleForm id="idPIRLeftInfo"
                                            class="sapUiSmallMarginEnd"
                                            width="auto"
                                        >

                                            <Title id="idMengeTitle" text="[ 수량 ]"/>

                                            <Label id="idPIRPlnmg" text="계획 수량"/>
                                            <ObjectNumber id="idPIRPlnmgObjectNumber"
                                                number="{detail>/PIRPlan/Plnmg}"
                                                unit="{detail>/PIRPlan/Meins}"
                                            />
                                            
                                            <Label id="idPIRPrdmg" text="생산 수량"/>
                                            <Text  id="idPIRPrdmgText" text="생산 수량" />                                        
                                        
                                            <Label id="idPIRVaria" text="수량 편차"/>
                                            <Text  id="idPIRVariaText" text="수량 편차" />

                                        </form:SimpleForm>

                                        <form:SimpleForm id="idPIRMidInfo"
                                            class="sapUiSmallMarginEnd"
                                            width="auto"
                                        >

                                            <Title id="idPIRRsnTitle" text="[ 사유 ]"/>

                                            <Label id="idPIRName" text="생성자 명"/>
                                            <Text  id="idPIRNameText" text="{detail>/PIRPlan/Name} ({detail>/PIRPlan/Ernam})" />
                                            
                                            <Label id="idPIRPrn" text="사유"/>
                                            <Text  id="idPIRPrnText" text="{detail>/PIRPlan/PirPrnDetail} ({detail>/PIRPlan/PirPrn})" />
                                            
                                            <Label id="idPIRRsnTx" text="상세 사유" />
                                            <Text  id="idPIRRsnText" text="{detail>/PIRPlan/PirRsntx}" />
                                            
                                        </form:SimpleForm>

                                        <form:SimpleForm id="idPIRRightInfo"
                                            class="sapUiSmallMarginEnd"
                                            width="auto"
                                        >
                                            
                                            <Title id="idDateTitle" text="[ 일자 ]"/>

                                            <Label id="idPIRErdat" text="계획 생성일"/>
                                            <Text  id="idPIRErdatText" 
                                                text="{
                                                    path: 'detail>/PIRPlan/Erdat',
                                                    type: 'sap.ui.model.type.Date',
                                                    formatOptions: { pattern: 'yyyy-MM-dd' }
                                                }" 
                                            />
                                            
                                            <Label id="idPIRBdter" text="생산일"/>
                                            <Text  id="idPIRBdterText" 
                                                text="{
                                                    path: 'detail>/PIRPlan/Bdter',
                                                    type: 'sap.ui.model.type.Date',
                                                    formatOptions: { pattern : 'yyyy-MM-dd' } 
                                                }" 
                                            />
                                            
                                            <Label id="idPIRLeadTime" text="리드타임"/>                               
                                            <Text  id="idPIRLeadTimeText" text="{detail>/PIRPlan/Ldtm} 일" />    

                                        </form:SimpleForm>

                                    </HBox>

                                    <viz:VizFrame id="idPIRChart"
                                        uiConfig="{applicationSet:'fiori'}"
                                        height="300px"
                                        width="100%"
                                        vizType="combination"
                                        vizProperties="{
                                            title: { text: '생산 수량 비교 분석 ' },
                                            valueAxis: {
                                                title: { visible: false }
                                            }
                                        }"
                                    >

                                        <viz:dataset>
                                            <data:FlattenedDataset id="idPIRFlattendDataset"
                                                data="{detail>/PIRChart}"
                                            >
                                                <data:dimensions>
                                                    <data:DimensionDefinition id="idPIRPlnmgLabel"
                                                        name="구분"
                                                        value="{detail>Label}"
                                                    />
                                                </data:dimensions>
                                                <data:measures>
                                                    <data:MeasureDefinition id="idPIRPlnmgValue"
                                                        name="수량"
                                                        value="{detail>Plnmg}"
                                                    />
                                                    <data:MeasureDefinition id="idPIRAvgmengeValue"
                                                        name="평균수량"
                                                        value="{detail>Avgmenge}"
                                                    />
                                                    <data:MeasureDefinition id="idPIRMinmengeValue"
                                                        name="최소수량"
                                                        value="{detail>Minmenge}"
                                                    />
                                                    <data:MeasureDefinition id="idPIRMaxmengeValue"
                                                        name="최대수량"
                                                        value="{detail>Maxmenge}"
                                                    />
                                                </data:measures>

                                            </data:FlattenedDataset>

                                        </viz:dataset>

                                        <viz:feeds>
                                            <feeds:FeedItem id="idPIRFeedItemCategory"
                                                uid="categoryAxis" 
                                                type="Dimension" 
                                                values="구분"
                                            />
                                            
                                            <feeds:FeedItem id="idPIRFeedItemComp"
                                                uid="valueAxis" 
                                                type="Measure" 
                                                values="수량,평균수량,최소수량,최대수량"

                                            />
                                            
                                        </viz:feeds>

                                        <viz:dependents>
                                            <viz:Popover id="idPopover" />
                                        </viz:dependents>

                                    </viz:VizFrame>

                                </VBox>

                            </form:SimpleForm>
                        </uxap:blocks>
                    </uxap:ObjectPageSubSection>
                </uxap:subSections>
            </uxap:ObjectPageSection>

        </uxap:sections>
    
    </uxap:ObjectPageLayout>

</core:FragmentDefinition>