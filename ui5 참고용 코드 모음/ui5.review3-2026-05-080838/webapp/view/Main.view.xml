<mvc:View 
    controllerName="code.t0.ui5.review3.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:t="sap.ui.table"
    xmlns:rowmodes="sap.ui.table.rowmodes"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <Panel
            id="idResponsiveTablePanel"
            headerText="Responsive Table(sap.m.Table) Panel"
            expandable="true"
            expanded="false"

            class="sapUiResponsiveMargin"
            width="auto"
            expand=".onPanelExpand"
        >
            <content>
                <!-- sap.m.Table -->
                <!-- 
                    sap.m.Table은 기본적으로 최대 100개의 항목을 표시한다.
                    하지만 growing 속성을 true로 설정하면, 사용자에 의해 더 많은 항목이 로드될 수 있다.
                -->

                <Table
                    id="idTable"
                    items="{/ZCDS_D00_Customer}"
                    growing="true"
                    growingThreshold="50"
                    class="sapUiResponsiveMargin"
                    width="auto"
                    itemPress=".onTopTableItemPress"
                    selectionChange=".onTopTableSelectionChange"
                    mode="MultiSelect"
                    alternateRowColors="true"                    
                >
                    <columns>
                        <Column>
                            <Text text="{i18n>Id}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>Name}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>Age}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>City}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Active">
                            <cells>
                                <ObjectIdentifier title="{Id}" />
                                <Text text="{Name}" />
                                <Text text="{Age}" />
                                <Text text="{City}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>

        <Panel 
            id="idGridTablePanel"
            headerText="Grid Table(sap.ui.table.Table) Panel"
            expandable="true"
            expanded="false"
            class="sapUiResponsiveMargin"
            width="auto"
        >
            <content>
                <t:Table
                    id="idGridTable"
                    rows="{/ZCDS_D00_Customer}"
                    cellClick=".onTableCellClick"
                    rowSelectionChange=".onTableRowSelectionChange"
                    selectionMode="MultiToggle"
                    selectionBehavior="Row"

                >
                    <!-- Panel과 ui.table.Table 이 이중으로 스크롤이 생기지 않도록 한다. -->
                    <t:rowMode>
                        <rowmodes:Auto minRowCount="5" ></rowmodes:Auto>
                    </t:rowMode>
                    <t:columns>
                        <t:Column>
                            <Text text="{i18n>Id}" />
                            <t:template>
                                <ObjectIdentifier title="{Id}" />
                            </t:template>
                        </t:Column>
                        <t:Column>
                            <Text text="{i18n>Name}" />
                            <t:template>
                                <Text text="{Name}" />
                            </t:template>
                        </t:Column>
                        <t:Column>
                            <Text text="{i18n>Age}" />
                            <t:template>
                                <Text text="{Age}" />
                            </t:template>   
                        </t:Column>
                        <t:Column>
                            <Text text="{i18n>City}" />
                            <t:template>
                                <Text text="{City}" />
                            </t:template>
                        </t:Column>
                    </t:columns>
                </t:Table>
            </content>
        
        </Panel>
    </Page>
</mvc:View>
