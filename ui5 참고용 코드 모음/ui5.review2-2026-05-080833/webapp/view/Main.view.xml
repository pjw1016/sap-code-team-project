<mvc:View
    controllerName="code.t0.ui5.review2.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <!-- sap.m.Page 를 의미한다. -->
    <Page
        id="page"
        title="{i18n>title}"
        class="sapUiResponsiveContentPadding"
    >
        <!-- sap.ui.layout.form.SimpleForm 를 의미한다. -->
        <form:SimpleForm
            layout="ResponsiveGridLayout"
            editable="true"
        >
            <form:toolbar>
                <Toolbar>
                    <Title text="신규 등록" />
                    <ToolbarSpacer />

                    <!-- onSave 메서드는 Main.controller.js 파일에 정의되어 있어야 합니다. 
                    이 메서드는 버튼이 눌렸을 때 실행될 함수를 지정합니다. -->
                    <Button
                        text="저장"
                        type="Emphasized"
                        press=".onSave"
                    />

                    <!-- onReset 메서드는 Main.controller.js 파일에 정의되어 있어야 합니다. 
                    이 메서드는 버튼이 눌렸을 때 실행될 함수를 지정합니다. -->
                    <Button
                        text="초기화"
                        type="Neutral"
                        press=".onReset"
                    />
                </Toolbar>
            </form:toolbar>
            <form:content>
                <core:Title text="기본정보" />
                <!-- sap.m.Label 를 의미한다. -->
                <Label text="이름" />
                <!-- sap.m.Input 를 의미한다. -->
                <Input value="{/name}" />

                <!-- sap.m.Label 를 의미한다. -->
                <Label text="나이" />
                <!-- sap.m.Input 를 의미한다. -->
                <Input value="{/age}" />

                <core:Title text="주소" />

                <!-- sap.m.Label 를 의미한다. -->
                <Label text="주소" />
                <!-- sap.m.Input 를 의미한다. -->
                <Input value="{/city}" />
            </form:content>
        </form:SimpleForm>
    </Page>
</mvc:View>
