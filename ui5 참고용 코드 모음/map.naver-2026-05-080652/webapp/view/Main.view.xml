<mvc:View
    controllerName="code.t0.map.naver.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page
        id="page"
        title="{i18n>title}"
        class="sapUiResponsiveContentPadding"
    >
        <Panel
            headerText=""
            height="100%"
        >
            <headerToolbar>
                <OverflowToolbar height="auto"  >
                    <Title text="네이버 지도" titleStyle="H3" />
                    <ToolbarSpacer />
                    <Button
                        text="주호타워로 이동하기"
                        type="Accept"
                        press=".onButtonPress"
                    />
                </OverflowToolbar>
            </headerToolbar>
            <content>
                <core:HTML
                    id="mapContainer"
                    content="&lt;div id='map' style='width:100%;height:100%;'>
                        &lt;div class='buttons'>
                        &lt;input id='NORMAL'    type='button' value='일반지도' class='control-btn control-on' />
                        &lt;input id='TERRAIN'   type='button' value='지형도'   class='control-btn' />
                        &lt;input id='SATELLITE' type='button' value='위성지도' class='control-btn' />
                        &lt;input id='HYBRID'    type='button' value='겹쳐보기' class='control-btn' />
                        &lt;/div>
                        &lt;/div>"
                />
            </content>
        </Panel>
    </Page>
</mvc:View>
