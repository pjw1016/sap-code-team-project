<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Popover
        id="myResizablePopover"
        title="{view>/name}"
        class="sapUiResponsivePadding--header sapUiResponsivePadding--footer"
        placement="HorizontalPreferredRight"
        resizable="true"
        initialFocus="close"

    >
        <content>
            <Image
                src="{view>/imgSrc}"
                width="700px"
                densityAware="true"
            />
        </content>
        <endButton>
            <Button
                icon="sap-icon://decline"
                press=".onPopoverClose"
            />
        </endButton>
        <footer>
            <OverflowToolbar>
                <ToolbarSpacer />
                <Button
                    text="Close"
                    press=".onPopoverClose"
                />
            </OverflowToolbar>
        </footer>
    </Popover>
</core:FragmentDefinition>
