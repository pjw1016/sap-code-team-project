<mvc:View
    controllerName="code.d00.expense.btrip.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <Panel
            headerText="{i18n>tripLookupPanelTitle}"
            class="sapUiResponsiveMargin"
            width="auto"
        >
            <content>
                <HBox
                    alignItems="Center"
                    wrap="Wrap"
                >
                    <Label
                        text="{i18n>tripIdLabel}"
                        labelFor="inpTripId"
                        width="8rem"
                    />
                    <Input
                        id="inpTripId"
                        width="16rem"
                        placeholder="{i18n>tripIdPlaceholder}"
                        valueLiveUpdate="true"
                        liveChange="onTripIdLiveChange"
                    />
                    <Button
                        text="{i18n>btnCheck}"
                        type="Emphasized"
                        class="sapUiTinyMarginBegin"
                        press="onCheckTrip"
                        enabled="{= ${ui>/tripIdValid} &amp;&amp; !${ui>/busy} }"
                    />
                    <ToolbarSpacer />
                    <BusyIndicator
                        visible="{ui>/busy}"
                        size="1.5rem"
                    />
                </HBox>
                <MessageStrip
                    class="sapUiSmallMarginTop"
                    visible="{= !${ui>/tripLoaded} }"
                    showIcon="true"
                    type="Information"
                    text="{i18n>hintSelectApprovedTrip}"
                />
            </content>
        </Panel>
        <VBox
            id="tripArea"
            visible="{ui>/tripLoaded}"
        >
            <Panel
                headerText="{i18n>tripDetailPanelTitle}"
                class="sapUiResponsiveMargin"
                width="auto"
            >
                <content>
                    <form:SimpleForm
                        editable="false"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsXL="2"
                        columnsL="2"
                        columnsM="1"
                        emptySpanXL="1"
                        emptySpanL="1"
                        emptySpanM="0"
                        emptySpanS="0"
                    >
                        <Label text="{i18n>colTripId}" />
                        <Text text="{TripID}" />
                        <Label text="{i18n>colEmpId}" />
                        <Text text="{EmpId}" />
                        <Label text="{i18n>colDest}" />
                        <Text text="{Dest}" />
                        <Label text="{i18n>colStat}" />
                        <Text text="{
                            path: 'Stat',
                            formatter: '.formatter.Stat'
                        }" />
                        <Label text="{i18n>colBgnDate}" />
                        <Text text="{
                            path: 'BgnDate',
                            type: 'sap.ui.model.type.DateTime',
                            formatOptions: {
                                pattern: 'yyyy-MM-dd'
                            }
                        }" />
                        <Label text="{i18n>colEndDate}" />
                        <Text text="{
                            path: 'EndDate',
                            type: 'sap.ui.model.type.DateTime',
                            formatOptions: {
                                pattern: 'yyyy-MM-dd'
                            }
                        }" />
                        <Label text="{i18n>colBudAmt}" />
                        <ObjectNumber number="{
                            parts: [{
                                path: 'BudAmt'
                            }, {
                                path: 'Waers'
                            }],
                            type: 'sap.ui.model.type.Currency'
                        }" />
                        <Label text="{i18n>colUseAmt}" />
                        <ObjectNumber number="{
                            parts: [{
                                path: 'UseAmt'
                            }, {
                                path: 'Waers'
                            }],
                            type: 'sap.ui.model.type.Currency'
                        }" />
                        <Label text="{i18n>colWaers}" />
                        <Text text="{Waers}" />
                        <Label text="{i18n>colCreatedAt}" />
                        <Text text="{
                            path: 'CreatedAt',
                            type: 'sap.ui.model.type.DateTime',
                            formatOptions: {
                                style: 'medium'
                            }
                        }" />
                        <Label text="{i18n>colNote}" />
                        <Text text="{Note}" />
                    </form:SimpleForm>
                </content>
            </Panel>
            <Panel
                headerText="{i18n>expenseListPanelTitle}"
                class="sapUiResponsiveMargin"
                width="auto"
            >
                <content>
                    <Table
                        id="tblExpenses"
                        mode="None"
                        growing="true"
                        growingScrollToLoad="true"
                        noDataText="{i18n>noExpenseData}"
                        items="{to_Expenses}"
                    >
                        <columns>
                            <Column width="7rem">
                                <Text text="{i18n>colExpId}" />
                            </Column>
                            <Column width="10rem">
                                <Text text="{i18n>colExpDate}" />
                            </Column>
                            <Column
                                hAlign="End"
                                width="12rem"
                            >
                                <Text text="{i18n>colExpAmt}" />
                            </Column>
                            <Column width="8rem">
                                <Text text="{i18n>colWaers}" />
                            </Column>
                            <Column width="20rem">
                                <Text text="{i18n>colExpNote}" />
                            </Column>
                            <Column width="10rem">
                                <Text text="{i18n>colErnam}" />
                            </Column>
                            <Column width="10rem">
                                <Text text="{i18n>colErdat}" />
                            </Column>
                            <Column width="8rem">
                                <Text text="{i18n>colErzet}" />
                            </Column>
                            <Column width="10rem">
                                <Text text="{i18n>colAenam}" />
                            </Column>
                            <Column width="10rem">
                                <Text text="{i18n>colAedat}" />
                            </Column>
                            <Column width="8rem">
                                <Text text="{i18n>colAezet}" />
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem>
                                <cells>
                                    <Text text="{ExpId}" />
                                    <Text text="{
                                        path: 'ExpDate',
                                        type: 'sap.ui.model.type.DateTime',
                                        formatOptions: {
                                            pattern: 'yyyy-MM-dd'
                                        }
                                    }" />
                                    <ObjectNumber number="{
                                        parts: [{
                                            path: 'ExpAmt'
                                        }, {
                                            path: 'Waers'
                                        }],
                                        type: 'sap.ui.model.type.Currency'
                                    }" />
                                    <Text text="{Waers}" />
                                    <Text text="{ExpNote}" />
                                    <Text text="{Ernam}" />
                                    <Text text="{
                                        path: 'Erdat',
                                        type: 'sap.ui.model.type.DateTime',
                                        formatOptions: {
                                            pattern: 'yyyy-MM-dd'
                                        }
                                    }" />
                                    <Text text="{Erzet}" />
                                    <Text text="{Aenam}" />
                                    <Text text="{
                                        path: 'Aedat',
                                        type: 'sap.ui.model.type.DateTime',
                                        formatOptions: {
                                            pattern: 'yyyy-MM-dd'
                                        }
                                    }" />
                                    <Text text="{Aezet}" />
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </content>
            </Panel>
            <Panel
                headerText="{i18n>newExpensePanelTitle}"
                class="sapUiResponsiveMargin"
                width="auto"
            >
                <content>
                    <form:SimpleForm
                        editable="true"
                        layout="ResponsiveGridLayout"
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="4"
                        labelSpanS="12"
                        columnsXL="2"
                        columnsL="2"
                        columnsM="1"
                        emptySpanXL="1"
                        emptySpanL="1"
                        emptySpanM="0"
                        emptySpanS="0"
                    >
                        <Label text="{i18n>colTripId}" />
                        <Input
                            value="{newExp>/TripID}"
                            editable="false"
                        />
                        <Label text="{i18n>colWaers}" />
                        <Input
                            value="{newExp>/Waers}"
                            editable="false"
                        />
                        <Label text="{i18n>colExpDate}" />
                        <DatePicker
                            value="{newExp>/ExpDate}"
                            valueFormat="yyyy-MM-dd"
                            displayFormat="yyyy-MM-dd"
                            enabled="{ui>/tripLoaded}"
                        />
                        <Label text="{i18n>colExpAmt}" />
                        <Input
                            value="{newExp>/ExpAmt}"
                            type="Number"
                            enabled="{ui>/tripLoaded}"
                        />
                        <Label text="{i18n>colExpNote}" />
                        <TextArea
                            value="{newExp>/ExpNote}"
                            rows="3"
                            growing="true"
                            enabled="{ui>/tripLoaded}"
                        />
                    </form:SimpleForm>
                    <HBox
                        justifyContent="End"
                        class="sapUiSmallMarginTop"
                        renderType="Bare"
                    >
                        <Button
                            id="btnSave"
                            text="{i18n>btnSave}"
                            type="Emphasized"
                            press="onSaveExpense"
                            enabled="{= ${ui>/tripLoaded} &amp;&amp; !${ui>/busy} }"
                        />
                        <Button
                            id="btnReset"
                            text="{i18n>btnReset}"
                            press="onResetExpense"
                            class="sapUiTinyMarginBegin"
                            enabled="{= ${ui>/tripLoaded} &amp;&amp; !${ui>/busy} }"
                        />
                    </HBox>
                </content>
            </Panel>
        </VBox>
    </Page>
</mvc:View>
