<mvc:View xmlns:core="sap.ui.core"
    controllerName="code.d00.expense.btrip.controller.Main2"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:form="sap.ui.layout.form"
>
    <Page
        id="page"
        title="{i18n>title}"
    >
        <Panel
            headerText="{i18n>tripLookupPanelTitle}"
            class="sapUiResponsiveMargin"
            width="auto"
        >
            <content>
                <HBox
                    alignItems="Center"
                    wrap="Wrap"
                >
                    <Label
                        text="{i18n>tripIdLabel}"
                        labelFor="inpTripId"
                        width="8rem"
                    />
                    <Input
                        id="inpTripId"
                        width="16rem"
                        placeholder="{i18n>tripIdPlaceholder}"
                        valueLiveUpdate="true"
                        liveChange="onTripIdLiveChange"
                    />
                    <Button
                        text="{i18n>btnCheck}"
                        type="Emphasized"
                        class="sapUiTinyMarginBegin"
                        press="onCheckTrip"
                        enabled="{= !!${ui>/tripIdValid} &amp;&amp; !${ui>/busy} }"
                    />
                    <ToolbarSpacer />
                    <BusyIndicator
                        visible="{ui>/busy}"
                        size="1.5rem"
                    />
                </HBox>
                <MessageStrip
                    class="sapUiSmallMarginTop"
                    visible="{= !${ui>/tripLoaded} }"
                    showIcon="true"
                    type="Information"
                    text="{i18n>hintSelectApprovedTrip}"
                />
            </content>
        </Panel>
        <Panel
            headerText="{i18n>tripDetailPanelTitle}"
            class="sapUiResponsiveMargin"
            width="auto"
            expandable="true"
        >
            <content>
                <form:SimpleForm
                    editable="false"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="4"
                    labelSpanL="5"
                    labelSpanM="5"
                    labelSpanS="12"
                    columnsXL="3"
                    columnsL="3"
                    columnsM="3"
                >  
                    <core:Title text="기본 정보" />
                    <Label text="{i18n>colTripId}" />
                    <Text text="{trip>/TripID}" />
                    <Label text="{i18n>colEmpId}" />
                    <Text text="{trip>/EmpID}" />
                    <Label text="{i18n>colDest}" />
                    <Text text="{trip>/Dest}" />
                    <Label text="{i18n>colBgnDate}" />
                    <Text text="{
                        path: 'trip>/BgnDate',
                        type: 'sap.ui.model.type.DateTime',
                        formatOptions: {
                            pattern: 'yyyy-MM-dd'
                        }
                    }" />
                    <Label text="{i18n>colEndDate}" />
                    <Text text="{
                        path: 'trip>/EndDate',
                        type: 'sap.ui.model.type.DateTime',
                        formatOptions: {
                            pattern: 'yyyy-MM-dd'
                        }
                    }" />
                    <core:Title text="금액 정보" />
                    <Label text="{i18n>colBudAmt}" />
                    <ObjectNumber number="{
                        parts: [{
                            path: 'trip>/BudAmt'
                        }, {
                            path: 'trip>/Waers'
                        }],
                        type: 'sap.ui.model.type.Currency'
                    }" />
                    <Label text="{i18n>colUseAmt}" />
                    <ObjectNumber number="{
                        parts: [{
                            path: 'trip>/UseAmt'
                        }, {
                            path: 'trip>/Waers'
                        }],
                        type: 'sap.ui.model.type.Currency'
                    }" />
                    <Label text="{i18n>colWaers}" />
                    <Text text="{trip>/Waers}" />
                    
                    <core:Title text="기타 정보" />
                    <!-- <Label text="{i18n>colStat}" />
                    <Text text="{
                        path: 'trip>/Stat',
                        formatter: '.formatter.Stat'
                    }" /> -->
                    <Label text="{i18n>colNote}" />
                    <Text text="{trip>/Note}" />
                    <Label text="{i18n>colCreatedAt}" />
                    <Text text="{
                        path: 'trip>/CreatedAt',
                        type: 'sap.ui.model.type.DateTime',
                        formatOptions: {
                            style: 'medium'
                        }
                    }" />
                </form:SimpleForm>
            </content>
        </Panel>
        <Panel
            headerText="{i18n>expenseListPanelTitle}"
            class="sapUiResponsiveMargin"
            width="auto"
            expandable="true"
        >
            <content>
                <Table
                    id="tblExpenses"
                    mode="None"
                    growing="true"
                    growingScrollToLoad="true"
                    noDataText="{i18n>noExpenseData}"
                    items="{
                        path: 'to_Expenses'
                    }"
                >
                    <columns>
                        <!-- <Column width="7rem"> -->
                        <Column>
                            <Text text="{i18n>colExpId}" />
                        </Column>
                        <!-- <Column width="10rem"> -->
                        <Column>
                            <Text text="{i18n>colExpDate}" />
                        </Column>
                        <!-- <Column
                            hAlign="End"
                            width="12rem"
                        > -->
                        <Column hAlign="End">
                            <Text text="{i18n>colExpAmt}" />
                        </Column>
                        <!-- <Column width="8rem"> -->
                        <Column>
                            <Text text="{i18n>colWaers}" />
                        </Column>
                        <!-- <Column width="20rem"> -->
                        <Column>
                            <Text text="{i18n>colExpNote}" />
                        </Column>
                        <!-- <Column width="10rem"> -->
                        <Column>
                            <Text text="{i18n>colErnam}" />
                        </Column>
                        <!-- <Column width="10rem"> -->
                        <Column>
                            <Text text="{i18n>colErdat}" />
                        </Column>
                        <!-- <Column width="8rem"> -->
                        <Column>
                            <Text text="{i18n>colErzet}" />
                        </Column>
                        <!-- <Column width="10rem"> -->
                        <Column>
                            <Text text="{i18n>colAenam}" />
                        </Column>
                        <!-- <Column width="10rem"> -->
                        <Column>
                            <Text text="{i18n>colAedat}" />
                        </Column>
                        <!-- <Column width="8rem"> -->
                        <Column>
                            <Text text="{i18n>colAezet}" />
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{ExpID}" />
                                <Text text="{
                                    path: 'ExpDate',
                                    type: 'sap.ui.model.type.DateTime',
                                    formatOptions: {
                                        pattern: 'yyyy-MM-dd'
                                    }
                                }" />
                                <ObjectNumber number="{
                                    parts: [{
                                        path: 'ExpAmt'
                                    }, {
                                        path: 'Waers'
                                    }],
                                    type: 'sap.ui.model.type.Currency'
                                }" />
                                <Text text="{Waers}" />
                                <Text text="{ExpNote}" />
                                <Text text="{Ernam}" />
                                <Text text="{
                                    path: 'Erdat',
                                    type: 'sap.ui.model.type.DateTime',
                                    formatOptions: {
                                        pattern: 'yyyy-MM-dd'
                                    }
                                }" />
                                <Text text="{
                                    path:'Erzet',
                                    type:'sap.ui.model.type.Time',
                                    formatOptions:{
                                        pattern: 'hh:mm:ss'
                                    }
                                }" />
                                <Text text="{Aenam}" />
                                <Text text="{
                                    path: 'Aedat',
                                    type: 'sap.ui.model.type.DateTime',
                                    formatOptions: {
                                        pattern: 'yyyy-MM-dd'
                                    }
                                }" />
                                <Text text="{
                                    path:'Aezet',
                                    type:'sap.ui.model.type.Time',
                                    formatOptions:{
                                        pattern: 'hh:mm:ss'
                                    }
                                }" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </content>
        </Panel>
        <Panel
            headerText="{i18n>newExpensePanelTitle}"
            class="sapUiResponsiveMargin"
            width="auto"
        >
            <content>
                <form:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    labelSpanXL="3"
                    labelSpanL="3"
                    labelSpanM="3"
                    labelSpanS="12"
                    columnsXL="1"
                    columnsL="1"
                    columnsM="1"
                >
                    <Label text="{i18n>colTripId}" />
                    <Input
                        value="{newExp>/TripID}"
                        editable="true"
                    />
                    <Label text="{i18n>colExpDate}" />
                    <DatePicker
                        value="{newExp>/ExpDate}"
                        valueFormat="yyyy-MM-dd"
                        displayFormat="yyyy-MM-dd"
                        enabled="{ui>/tripLoaded}"
                    />
                    <Label text="{i18n>colExpAmt}" />
                    <Input
                        value="{newExp>/ExpAmt}"
                        type="Number"
                        enabled="{ui>/tripLoaded}"
                    />
                    <Label text="{i18n>colWaers}" />
                    <Input
                        value="{newExp>/Waers}"
                        editable="false"
                    />
                    <Label text="{i18n>colExpNote}" />
                    <TextArea
                        value="{newExp>/ExpNote}"
                        rows="3"
                        growing="true"
                        enabled="{ui>/tripLoaded}"
                    />
                </form:SimpleForm>
                <HBox
                    justifyContent="End"
                    class="sapUiSmallMarginTop"
                    renderType="Bare"
                >
                    <Button
                        id="btnSave"
                        text="{i18n>btnSave}"
                        type="Emphasized"
                        press="onSaveExpense"
                        enabled="{= ${ui>/tripLoaded} &amp;&amp; !${ui>/busy} }"
                    />
                    <Button
                        id="btnReset"
                        text="{i18n>btnReset}"
                        press="onResetExpense"
                        class="sapUiTinyMarginBegin"
                        enabled="{= ${ui>/tripLoaded} &amp;&amp; !${ui>/busy} }"
                    />
                </HBox>
            </content>
        </Panel>
    </Page>
</mvc:View>
