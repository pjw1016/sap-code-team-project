<!--
    SAPUI5의 XML View 파일.

    View는 화면의 구조를 선언하는 영역이다.
    실제 데이터 생성과 이벤트 처리는 Controller에서 담당하고,
    View는 어떤 UI 컨트롤을 어떤 구조로 배치할지 정의한다.
-->

<!--
    mvc:View는 SAPUI5 MVC 구조에서 View의 최상위 태그다.

    controllerName은 이 View와 연결될 Controller의 전체 경로를 의미한다.
    이 값은 Main.controller.js 안의 Controller.extend(...) 이름과 일치해야 한다.

    xmlns:mvc는 mvc:View 같은 MVC 전용 태그를 사용하기 위한 네임스페이스다.
    xmlns="sap.m"은 Page, Table, Column, Text 같은 sap.m 컨트롤을 접두어 없이 사용할 수 있게 하는 기본 네임스페이스다.
-->
<mvc:View
    controllerName="code.d00.even.multiplication.table.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <!--
        Page는 하나의 화면 단위를 구성하는 컨테이너다.
        상단 제목 영역과 본문 영역을 함께 가진다.

        title="{i18n>title}"은 i18n 모델에서 title 값을 가져와 제목으로 표시한다.
        i18n은 다국어 텍스트를 관리할 때 사용하는 리소스 모델이다.
    -->
    <Page
        id="idPage"
        title="{i18n>title}"
    >
        <!--
            Table은 행과 컬럼으로 데이터를 표시하는 컨트롤이다.

            id="idDataTable"은 Controller에서 this.byId("idDataTable")로
            이 테이블을 찾기 위해 사용된다.

            columns="{column>/Columns}"는 column 모델의 /Columns 배열을
            테이블의 컬럼 목록에 바인딩한다.

            Controller에서는 다음 코드로 column 모델을 등록한다.
            oView.setModel(new JSONModel({ Columns: aColumnsText }), "column");

            /Columns 배열의 객체 하나가 테이블 컬럼 하나로 해석된다.
        -->
        <Table
            id="idDataTable"
            columns="{column>/Columns}"
        >
            <!--
                columns aggregation은 테이블의 컬럼 구조를 정의하는 영역이다.

                위의 columns 바인딩 때문에 이 안의 Column은 템플릿 역할을 한다.
                즉, /Columns 배열의 길이만큼 Column이 반복 생성된다.
            -->
            <columns>
                <Column>
                    <!--
                        column 모델의 현재 컬럼 객체에서 columnText 값을 읽어 표시한다.

                        예:
                        { columnText: "2단" }이면 "2단"이 출력된다.
                    -->
                    <Text text="{column>columnText}" />
                </Column>
            </columns>

            <!--
                items aggregation은 테이블의 행 데이터를 정의하는 영역이다.

                이 파일에서는 비워 두고,
                Controller의 _createTableItems 함수에서 bindItems(...)로 동적으로 생성한다.
            -->
            <!-- <items></items> -->
        </Table>
    </Page>
</mvc:View>
