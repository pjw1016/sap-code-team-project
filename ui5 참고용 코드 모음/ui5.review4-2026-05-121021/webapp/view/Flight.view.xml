<mvc:View
    controllerName="code.t0.ui5.review4.controller.Flight"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:table="sap.ui.table"
    xmlns:rowmodes="sap.ui.table.rowmodes"
    xmlns:core="sap.ui.core"
>
    <f:DynamicPage
        toggleHeaderOnTitleClick="false"
        class="sapUiResponsiveContentPadding"
    >
        <f:title>
            <f:DynamicPageTitle>
                <f:heading>
                    <FlexBox
                        wrap="Wrap"
                        fitContainer="true"
                        alignItems="Center"
                    >
                        <!-- Flight.controller.js에서 /ConnectionSet(...)에 bindElement하고 to_Carrier를 expand했기 때문에 상대경로로 항공사명을 읽는다. -->
                        <Title text="{to_Carrier/Carrname}, {Connid}" />
                    </FlexBox>
                </f:heading>

                <f:navigationActions>
                    <!-- endColumn 버튼의 노출 여부와 다음 layout 값은 config 모델의 actionButtonsInfo에서 온다. -->
                    <OverflowToolbarButton
                        type="Transparent"
                        icon="sap-icon://full-screen"
                        press=".onOverflowToolbarButton_FullScreen_Press"
                        tooltip="Enter Full Screen Mode"
                        visible="{= ${config>/actionButtonsInfo/endColumn/fullScreen} !== null }"
                    />
                    <OverflowToolbarButton
                        type="Transparent"
                        icon="sap-icon://exit-full-screen"
                        press=".onOverflowToolbarButton_ExitFullScreen_Press"
                        tooltip="Exit Full Screen Mode"
                        visible="{= ${config>/actionButtonsInfo/endColumn/exitFullScreen} !== null }"
                    />
                    <OverflowToolbarButton
                        type="Transparent"
                        icon="sap-icon://decline"
                        press=".onOverflowToolbarButton_Close_Press"
                        tooltip="Close column"
                        visible="{= ${config>/actionButtonsInfo/endColumn/closeColumn} !== null }"
                    />
                </f:navigationActions>
            </f:DynamicPageTitle>
        </f:title>
        <f:content>
            <FlexBox
                class="sapUiSmallMargin flightPageContent"
                direction="Column"
                fitContainer="true"
            >
                <Link
                    text="다음 페이지로 이동…"
                    press=".onNavigateToNextPageLinkPress"
                    class="sapUiSmallMarginBottom"

                />

                <!--
                    현재 View는 Flight.controller.js에서 /ConnectionSet(Carrid='...',Connid='...')에 bindElement된다.
                    ConnectionSetType의 navigation property인 to_Flight를 rows에 상대 바인딩하여 해당 연결편의 비행일정을 출력한다.
                -->
                <table:Table
                    id="idFlightTable"
                    class="flightTable"
                    rows="{to_Flight}"
                    selectionMode="None"
                    width="100%"
                >
                    <table:extension>
                        <OverflowToolbar height="auto">
                            <Title
                                text="{i18n>flightScheduleTitle}"
                                class="sapUiSmallMarginBegin sapUiTinyMarginTopBottom flightTitle"
                                titleStyle="H4"
                            />
                            <core:Icon
                                src="sap-icon://flight"
                                size="1.5rem"
                                color="#2d96d7"
                                hoverColor="#000000"
                                activeColor="rgba(52, 205, 180, 0.54)"
                            />
                        </OverflowToolbar>
                    </table:extension>
                    <table:layoutData>
                        <!-- Column 방향 FlexBox 안에서 Link/Title을 제외한 남은 세로 공간을 Table이 차지하게 한다. -->
                        <FlexItemData
                            growFactor="1"
                            baseSize="0"
                        />
                    </table:layoutData>
                    <table:rowMode>
                        <rowmodes:Auto />
                    </table:rowMode>
                    <table:columns>
                        <table:Column width="9rem">
                            <Label text="{i18n>columnFlightDate}" />
                            <table:template>
                                <Text
                                    text="{
                                        path: 'Fldate',
                                        type: 'sap.ui.model.type.Date',
                                        formatOptions: {
                                            pattern: 'yyyy-MM-dd'
                                        }
                                    }"
                                />
                            </table:template>
                        </table:Column>
                        <table:Column
                            width="8rem"
                            hAlign="End"
                        >
                            <Label text="{i18n>columnAirfare}" />
                            <table:template>
                                <ObjectNumber
                                    textAlign="End"
                                    number="{
                                        parts: ['Price', 'Currency'],
                                        type: 'sap.ui.model.type.Currency',
                                        formatOptions: {
                                            showMeasure: false
                                        }
                                    }"
                                    unit="{Currency}"
                                />
                            </table:template>
                        </table:Column>
                        <table:Column width="8rem">
                            <Label text="{i18n>columnPlaneType}" />
                            <table:template>
                                <Text text="{Planetype}" />
                            </table:template>
                        </table:Column>
                        <table:Column
                            width="7rem"
                            hAlign="End"
                        >
                            <Label text="{i18n>columnSeatsEconomy}" />
                            <table:template>
                                <Text text="{Seatsocc} / {Seatsmax}" />
                            </table:template>
                        </table:Column>
                        <table:Column
                            width="7rem"
                            hAlign="End"
                        >
                            <Label text="{i18n>columnSeatsBusiness}" />
                            <table:template>
                                <Text text="{SeatsoccB} / {SeatsmaxB}" />
                            </table:template>
                        </table:Column>
                        <table:Column
                            width="7rem"
                            hAlign="End"
                        >
                            <Label text="{i18n>columnSeatsFirst}" />
                            <table:template>
                                <Text text="{SeatsoccF} / {SeatsmaxF}" />
                            </table:template>
                        </table:Column>
                        <table:Column
                            width="9rem"
                            hAlign="End"
                        >
                            <Label text="{i18n>columnBookingTotal}" />
                            <table:template>
                                <ObjectNumber
                                    textAlign="End"
                                    number="{
                                        parts: ['Paymentsum','Currency'],
                                        type: 'sap.ui.model.type.Currency',
                                        formatOptions: {
                                            showMeasure: false
                                        }
                                    }"
                                    unit="{Currency}"
                                />
                            </table:template>
                        </table:Column>
                    </table:columns>
                </table:Table>
            </FlexBox>
        </f:content>
    </f:DynamicPage>
</mvc:View>
