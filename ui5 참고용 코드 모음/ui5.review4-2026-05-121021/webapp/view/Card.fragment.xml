<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.f"
    xmlns:card="sap.f.cards"
>
    <Popover
        placement="Right"
        showHeader="false"
        contentWidth="300px"
    >
        <f:Card width="300px">
            <f:header>
                <card:NumericHeader
                    title="매출이익"
                    subtitle="당기 변화량"
                    unitOfMeasurement="KRW"
                    number="21.8"
                    scale="B"
                    trend="Down"
                    state="Critical"
                >
                    <card:sideIndicators>
                        <card:NumericSideIndicator
                            number="30"
                            unit="B"
                            title="전기"
                        />
                        <card:NumericSideIndicator
                            number="-27.33"
                            unit="%"
                            title="증감율"
                        />
                    </card:sideIndicators>
                </card:NumericHeader>
            </f:header>
        </f:Card>
    </Popover>
</core:FragmentDefinition>
