<mvc:View
    controllerName="code.t0.ui5.review1.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <!-- sap.m.Page 를 의미한다. -->
    <Page
        id="page"
        title="{i18n>title}"
        class="sapUiResponsiveContentPadding"
    >
        <!-- 
            sap.m.Text 를 의미한다.
            class="sapUiLargeMarginBottom" : 아래(Bottom)에 큰 여백(Large Margin)을 만든다
            class="sapUiMediumMarginBegin sapUiSmallMarginEnd" : 왼쪽(Begin)에 중간 여백(Medium Margin)을 만들고, 오른쪽(End)에 작은 여백(Small Margin)을 만든다.
        -->
        <Text
            text="Hello World!"
            class="sapUiLargeMarginBottom"
        />
        <Text
            text="Hello World!"
            class="sapUiMediumMarginBegin sapUiSmallMarginEnd"
        />

        <!-- sap.m.Button 을 의미한다. -->
        <!-- Text와 Button은 기본적으로 한 줄에 여러 개 출력된다. -->
        <Button text="1 버튼입니다." />
        <Button text="2 버튼입니다." />
        <Button text="3 버튼입니다." />

        <!-- VBox를 사용하면 한 줄에 하나씩 출력시켜 수직으로 생성하도록 한다. -->
        <VBox>
            <Button text="4 버튼입니다." />
            <Button text="5 버튼입니다." />
            <Button text="6 버튼입니다." />
        </VBox>

        <!-- sap.m.Input 을 의미한다. -->
        <!-- Input은 기본적으로 한 줄에 하나씩 출력된다. -->
        <Input value="1 입력필드 입니다." />
        <Input value="2 입력필드 입니다." />
        <Input value="3 입력필드 입니다." />

        <!-- HBox를 사용하면 한 줄에 여러 개를 출력시켜 수평으로 생성하도록 한다. -->
        <HBox>
            <Input value="4 입력필드 입니다." />
            <Input value="5 입력필드 입니다." />
            <Input value="6 입력필드 입니다." />
        </HBox>

        <!-- VBox 와 HBox 를 조합하면 Label + Input 조합을 sap.ui.layout.form.SimpleForm 없이도 디자인을 꾸밀 수 있다. -->
        <VBox>
            <!-- alignItems="Stretch" : 하위 항목들의 높이를 맞춤, 높이를 늘리는 것만 있어서 문자 등 컨텐츠는 중앙으로 내려가지 않고, 위에 그대로 있음   -->
            <HBox alignItems="Stretch">
                <!-- sap.m.Text 를 의미한다. -->
                <Label
                    text="이름"
                    class="sapUiTinyMarginEnd"
                />
                <!-- sap.m.Input 를 의미한다. -->
                <Input />
            </HBox>

            <!-- alignItems="Center" : 하위 항목들을 중앙에 위치시킴, 높이를 늘리진 않지만 수직 중앙에 있어서 훨씬 보기가 좋음 -->
            <HBox alignItems="Center">
                <!-- sap.m.Text 를 의미한다. -->
                <Label
                    text="나이"
                    class="sapUiTinyMarginEnd"
                />
                <!-- sap.m.Input 를 의미한다. -->
                <Input />
            </HBox>

            <!-- alignItems="End" : 하위 항목들을 아래로 위치시킴 -->
            <HBox alignItems="End">
                <!-- sap.m.Text 를 의미한다. -->
                <Label
                    text="주소"
                    class="sapUiTinyMarginEnd"
                />
                <!-- sap.m.Input 를 의미한다. -->
                <Input />
            </HBox>
        </VBox>
    </Page>
</mvc:View>
