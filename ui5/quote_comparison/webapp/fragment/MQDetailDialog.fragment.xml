<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="idMqDetailDialog"
        title="{= ${detail>/MqDetail/MqNo} ? ${i18n>mqDetail} + ' - ' + ${detail>/MqDetail/MqNo} : ${i18n>mqDetail} }"
        contentWidth="60rem"
        contentHeight="42rem"
        draggable="true"
        resizable="true">
        <content>
            <ScrollContainer
                width="100%"
                height="100%"
                vertical="true">
                <VBox class="sapUiSmallMargin">
                    <Title
                        text="{i18n>detailBasicInfo}"
                        level="H3"/>
                    <!-- 팝업 폭을 효율적으로 쓰기 위해 라벨/값 한 쌍을 27rem 단위로 묶고, FlexBox가 두 묶음씩 좌우 배치하도록 한다. -->
                    <FlexBox
                        wrap="Wrap"
                        renderType="Bare">
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>rfqNo}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/RfqNo}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>rfqItem}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/RfqItem}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>mqNo}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/MqNo}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>mqItem}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/MqItem}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>lifnr}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/Lifnr}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>name1}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/Name1}"
                                wrapping="true"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>matnr}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/Matnr}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>maktx}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/Maktx}"
                                wrapping="true"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>werks}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/Werks} {detail>/MqDetail/WerksName}"
                                wrapping="true"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>lgort}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/Lgort} {detail>/MqDetail/Lgobe}"
                                wrapping="true"/>
                        </HBox>
                    </FlexBox>

                    <Title
                        text="{i18n>detailQuotationInfo}"
                        level="H3"
                        class="sapUiSmallMarginTop"/>
                    <!-- 견적 금액 영역도 기본정보와 같은 2열 규칙을 사용해 환율, 단가, 환산총액을 한눈에 비교하게 한다. -->
                    <FlexBox
                        wrap="Wrap"
                        renderType="Bare">
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>quoteQty}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectNumber
                                number="{path: 'detail>/MqDetail/QuoteQty', formatter: '.formatter.formatQuantity'}"
                                unit="{detail>/MqDetail/Meins}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>netpr}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectNumber
                                number="{path: 'detail>/MqDetail/Netpr', formatter: '.formatter.formatAmount'}"
                                unit="{detail>/MqDetail/Waers}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>peinh}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectNumber
                                number="{path: 'detail>/MqDetail/Peinh', formatter: '.formatter.formatQuantity'}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>netwr}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectNumber
                                number="{path: 'detail>/MqDetail/Netwr', formatter: '.formatter.formatAmount'}"
                                unit="{detail>/MqDetail/Waers}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>exchangeDate}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{path: 'detail>/MqDetail/ExchangeDate', formatter: '.formatter.formatDate'}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>kursf}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <!-- 환율은 Scale=5인 값이므로 금액 formatter가 아니라 환율 전용 formatter로 표시한다. -->
                            <ObjectNumber
                                number="{path: 'detail>/MqDetail/Kursf', formatter: '.formatter.formatExchangeRate'}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>netprKrw}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectNumber
                                number="{path: 'detail>/MqDetail/NetprKrw', formatter: '.formatter.formatAmount'}"
                                unit="{detail>/MqDetail/Kwaers}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>netwrKrw}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectNumber
                                number="{path: 'detail>/MqDetail/NetwrKrw', formatter: '.formatter.formatAmount'}"
                                unit="{detail>/MqDetail/Kwaers}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>eindt}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{path: 'detail>/MqDetail/Eindt', formatter: '.formatter.formatDate'}"/>
                        </HBox>
                    </FlexBox>

                    <Title
                        text="{i18n>detailReferenceInfo}"
                        level="H3"
                        class="sapUiSmallMarginTop"/>
                    <!-- 참조정보의 긴 설명 필드는 줄바꿈을 허용하고, 일반 필드는 기본 2열 배치에 맞춘다. -->
                    <FlexBox
                        wrap="Wrap"
                        renderType="Bare">
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>bukrs}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/Bukrs} {detail>/MqDetail/Butxt}"
                                wrapping="true"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>ekorg}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/Ekorg} {detail>/MqDetail/Ekotx}"
                                wrapping="true"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>ekgrp}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/Ekgrp} {detail>/MqDetail/Eknam}"
                                wrapping="true"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>banfn}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/Banfn}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>zterm}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/Zterm}"/>
                        </HBox>
                        <HBox width="54rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>headTxt}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/HeadTxt}"
                                wrapping="true"/>
                        </HBox>
                    </FlexBox>

                    <Title
                        text="{i18n>detailStatusInfo}"
                        level="H3"
                        class="sapUiSmallMarginTop"/>
                    <!-- 상태정보는 채택 가능 여부와 차단 사유를 함께 확인해야 하므로 상세 팝업 안에 계속 노출한다. -->
                    <FlexBox
                        wrap="Wrap"
                        renderType="Bare">
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>responseStatus}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectStatus
                                text="{detail>/MqDetail/ResponseStatusText}"
                                state="{path: 'detail>/MqDetail/ResponseStatus', formatter: '.formatter.formatResponseState'}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>currentAward}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectStatus
                                text="{path: 'detail>/MqDetail/CurrentAwardYn', formatter: '.formatter.formatBooleanText'}"
                                state="{path: 'detail>/MqDetail/CurrentAwardYn', formatter: '.formatter.formatBooleanState'}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>recommend}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectStatus
                                text="{path: 'detail>/MqDetail/RecommendYn', formatter: '.formatter.formatBooleanText'}"
                                state="{path: 'detail>/MqDetail/RecommendYn', formatter: '.formatter.formatBooleanState'}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>poCreated}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectStatus
                                text="{path: 'detail>/MqDetail/PoCreatedYn', formatter: '.formatter.formatBooleanText'}"
                                state="{path: 'detail>/MqDetail/PoCreatedYn', formatter: '.formatter.formatBooleanState'}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>poNo}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/PoNo}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>poItem}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text text="{detail>/MqDetail/PoItem}"/>
                        </HBox>
                        <HBox width="27rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>canSelect}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <ObjectStatus
                                text="{path: 'detail>/MqDetail/CanSelect', formatter: '.formatter.formatCanSelectText'}"
                                state="{path: 'detail>/MqDetail/CanSelect', formatter: '.formatter.formatCanSelectState'}"/>
                        </HBox>
                        <HBox width="54rem" class="sapUiTinyMarginBottom">
                            <Label text="{i18n>blockReason}" width="8rem" textAlign="End" class="sapUiTinyMarginEnd"/>
                            <Text
                                text="{detail>/MqDetail/BlockReason}"
                                wrapping="true"/>
                        </HBox>
                    </FlexBox>
                </VBox>
            </ScrollContainer>
        </content>
        <beginButton>
            <Button
                text="{i18n>selectThisMq}"
                type="Emphasized"
                enabled="{= ${detail>/MqDetail/CanSelect} === 'X' }"
                press=".onSelectMqFromDialog"/>
        </beginButton>
        <endButton>
            <Button
                text="{i18n>close}"
                press=".onCloseMqDetailDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
