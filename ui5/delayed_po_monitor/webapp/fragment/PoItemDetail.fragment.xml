<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        id="poItemDetailDialog"
        title="{i18n>detailDialogTitle}"
        contentWidth="72rem"
        contentHeight="42rem"
        draggable="true"
        resizable="true"
        stretchOnPhone="true">
        <content>
            <VBox class="sapUiSmallMargin">
                <!-- <HBox alignItems="Center" class="dpmDialogHeader">
                    <ObjectIdentifier
                        title="{detail>/Ebeln}"
                        text="{= ${i18n>detailItemLabel} + ' ' + ${detail>/Ebelp} }"/>
                    <ToolbarSpacer/>
                    <ObjectStatus
                        text="{detail>/StatusText}"
                        state="{detail>/StatusState}"/>
                </HBox> -->

                <!-- 상세 팝업 헤더. 선택한 PO번호와 현재 입고 상태를 가장 위에서 보여준다. -->
                <HBox alignItems="Start" class="dpmDialogHeader">
                    <VBox>
                        <HBox alignItems="Center">
                            <Title
                                text="{detail>/Ebeln}"
                                level="H2"
                                class="sapUiTinyMarginEnd"/>

                            <ObjectStatus
                                text="{detail>/StatusText}"
                                state="{detail>/StatusState}"/>
                        </HBox>

                        <Text
                            text="{parts: [
                                    {path: 'i18n>detailItemLabel'},
                                    {path: 'detail>/Ebelp'}
                                ],
                                formatter: '.formatter.formatItemLabel'}"/>
                    </VBox>
                </HBox>

                <!-- 선택한 PO Item의 기본 master/detail 정보 영역이다. -->
                <Panel headerText="{i18n>detailBasicInfo}" class="dpmDialogSection">
                    <content>
                        <FlexBox wrap="Wrap" renderType="Bare" class="dpmInfoGrid">
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>colLifnr}"/>
                                <Text text="{detail>/Lifnr}"/>
                            </VBox>
                            <VBox class="dpmInfoItemWide">
                                <Label text="{i18n>colName1}"/>
                                <Text text="{detail>/Name1}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>colMatnr}"/>
                                <Text text="{detail>/Matnr}"/>
                            </VBox>
                            <VBox class="dpmInfoItemWide">
                                <Label text="{i18n>colMaktx}"/>
                                <Text text="{detail>/Maktx}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>colEindt}"/>
                                <Text text="{path: 'detail>/Eindt', formatter: '.formatter.formatDate'}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>werks}"/>
                                <Text text="{detail>/Werks}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>lgort}"/>
                                <Text text="{detail>/Lgort}"/>
                            </VBox>
                        </FlexBox>
                    </content>
                </Panel>

                <!--
                    수량 및 상태 요약 영역.
                    101/102 수량, 실제 입고수량, 미입고수량, 기준일, 지연일수를 함께 보여준다.
                -->
                <Panel headerText="{i18n>detailQtyInfo}" class="dpmDialogSection">
                    <content>
                        <FlexBox wrap="Wrap" renderType="Bare" class="dpmInfoGrid">
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>colPoQty}"/>
                                <ObjectNumber number="{path: 'detail>/PoQty', formatter: '.formatter.formatQuantity'}" unit="{detail>/Meins}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>gr101Qty}"/>
                                <ObjectNumber number="{path: 'detail>/Gr101Qty', formatter: '.formatter.formatQuantity'}" unit="{detail>/Meins}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>gr102Qty}"/>
                                <ObjectNumber number="{path: 'detail>/Gr102Qty', formatter: '.formatter.formatQuantity'}" unit="{detail>/Meins}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>colGrQty}"/>
                                <ObjectNumber number="{path: 'detail>/GrQty', formatter: '.formatter.formatQuantity'}" unit="{detail>/Meins}"/>
                            </VBox>
                            <VBox class="dpmReceiptRateItem">
                                <Label text="{i18n>receiptRate}"/>
                                <!-- 입고율 = 입고수량 / 발주수량. 초과입고는 표시 텍스트에서 100% 이상으로 보일 수 있다. -->
                                <ProgressIndicator
                                    percentValue="{parts: [
                                            {path: 'detail>/PoQty'},
                                            {path: 'detail>/GrQty'}
                                        ],
                                        formatter: '.formatter.formatReceiptRatePercent'}"
                                    displayValue="{parts: [
                                            {path: 'detail>/PoQty'},
                                            {path: 'detail>/GrQty'}
                                        ],
                                        formatter: '.formatter.formatReceiptRateText'}"
                                    state="{parts: [
                                            {path: 'detail>/PoQty'},
                                            {path: 'detail>/GrQty'}
                                        ],
                                        formatter: '.formatter.formatReceiptRateState'}"
                                    showValue="true"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>colOpenQty}"/>
                                <ObjectNumber number="{path: 'detail>/OpenQty', formatter: '.formatter.formatQuantity'}" unit="{detail>/Meins}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>baseDate}"/>
                                <Text text="{path: 'detail>/BaseDate', formatter: '.formatter.formatDate'}"/>
                            </VBox>
                            <VBox class="dpmInfoItem">
                                <Label text="{i18n>colDelayDays}"/>
                                <Text text="{path: 'detail>/DelayDays', formatter: '.formatter.formatDelayDays'}"/>
                            </VBox>
                        </FlexBox>
                    </content>
                </Panel>

                <!--
                    101/102 개별 입고 이력 테이블.
                    수량 자체는 원문 MENGE이고, 계산반영수량은 Gateway에서 101은 +, 102는 -로 계산한다.
                -->
                <Table
                    id="grHistoryTable"
                    items="{grHistory>/items}"
                    busy="{grHistory>/busy}"
                    growing="true"
                    growingThreshold="10">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{i18n>historyTableTitle}" level="H3"/>
                            <Title
                                text="{= ${i18n>countUnit1} + ' ' + ${grHistory>/items}.length + ' ' + ${i18n>countUnit2} }"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column><Text text="{i18n>histMblnr}"/></Column>
                        <Column width="5rem"><Text text="{i18n>histMjahr}"/></Column>
                        <Column width="5rem"><Text text="{i18n>histZeile}"/></Column>
                        <Column width="6rem"><Text text="{i18n>histBwart}"/></Column>
                        <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>histBwartText}"/></Column>
                        <Column width="7rem"><Text text="{i18n>histBudat}"/></Column>
                        <Column width="7rem"><Text text="{i18n>histBldat}"/></Column>
                        <Column width="8rem" hAlign="End"><Text text="{i18n>histMenge}"/></Column>
                        <Column width="9rem" hAlign="End"><Text text="{i18n>histSignedQty}"/></Column>
                        <Column width="8rem"><Text text="{i18n>histSignText}"/></Column>
                    </columns>
                    <items>
                        <ColumnListItem
                            highlight="{path: 'grHistory>SignedQty', formatter: '.formatter.formatSignedQtyState'}"
                            highlightText="{grHistory>SignText}">
                            <cells>
                                <!-- 자재문서 Key 및 이동유형 정보 -->
                                <Text text="{grHistory>Mblnr}"/>
                                <Text text="{grHistory>Mjahr}"/>
                                <Text
                                    text="{path: 'grHistory>Zeile', formatter: '.formatter.formatItemNo'}"
                                    wrapping="false"/>
                                <Text text="{grHistory>Bwart}"/>
                                <Text text="{grHistory>BwartText}"/>
                                <Text text="{path: 'grHistory>Budat', formatter: '.formatter.formatDate'}"/>
                                <Text text="{path: 'grHistory>Bldat', formatter: '.formatter.formatDate'}"/>
                                <ObjectNumber
                                    number="{path: 'grHistory>Menge', formatter: '.formatter.formatQuantity'}"
                                    unit="{grHistory>Meins}"/>
                                <!-- 102 취소는 음수로 표시해 실제 입고수량 계산 방향을 분명하게 보여준다. -->
                                <ObjectNumber
                                    number="{path: 'grHistory>SignedQty', formatter: '.formatter.formatSignedQuantity'}"
                                    unit="{grHistory>Meins}"
                                    state="{path: 'grHistory>SignedQty', formatter: '.formatter.formatSignedQtyState'}"/>
                                <Text text="{grHistory>SignText}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
        <endButton>
            <Button text="{i18n>close}" press=".onCloseDetailDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
