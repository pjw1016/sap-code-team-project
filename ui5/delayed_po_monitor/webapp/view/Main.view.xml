<mvc:View
    controllerName="code.d3.delayedpomonitor.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds">
    <Page id="page" title="{i18n>title}">
        <content>
            <VBox class="dpmPage sapUiResponsiveContentPadding">
                <!--
                    검색조건 영역.
                    기준일/납기일/플랜트/상태는 기본 조건이고,
                    회사코드/PO/공급업체/자재 조건은 상세조건으로 접어둔다.
                -->
                <Panel headerText="{i18n>searchPanelTitle}" class="dpmSection" expandable="true" expanded="true">
                    <content>
                        <VBox class="sapUiSmallMargin">
                            <FlexBox wrap="Wrap" renderType="Bare" class="dpmFilterBar">
                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>baseDate}" labelFor="baseDatePicker"/>
                                    <DatePicker
                                        id="baseDatePicker"
                                        dateValue="{view>/filters/baseDate}"
                                        displayFormat="yyyy-MM-dd"
                                        valueFormat="yyyy-MM-dd"
                                        change=".onBaseDateChange"/>
                                </VBox>

                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>eindtFrom}" labelFor="eindtFromPicker"/>
                                    <DatePicker
                                        id="eindtFromPicker"
                                        dateValue="{view>/filters/eindtFrom}"
                                        displayFormat="yyyy-MM-dd"
                                        valueFormat="yyyy-MM-dd"/>
                                </VBox>

                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>eindtTo}" labelFor="eindtToPicker"/>
                                    <DatePicker
                                        id="eindtToPicker"
                                        dateValue="{view>/filters/eindtTo}"
                                        displayFormat="yyyy-MM-dd"
                                        valueFormat="yyyy-MM-dd"/>
                                </VBox>

                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>werks}" labelFor="werksInput"/>
                                    <Input
                                        id="werksInput"
                                        value="{view>/filters/werks}"
                                        maxLength="6"
                                        placeholder="{i18n>allPlaceholder}"
                                        showValueHelp="true"
                                        valueHelpRequest=".onValueHelpRequest">
                                        <customData>
                                            <!--
                                                Search Help 공통 핸들러에서 어떤 CDS OData를 열지 구분하는 값이다.
                                                PLANT는 ZCDS_D3_MM_0012_CDS 모델을 사용한다.
                                            -->
                                            <core:CustomData key="helpType" value="PLANT"/>
                                        </customData>
                                    </Input>
                                </VBox>

                                <VBox class="dpmFilterItemWide">
                                    <Label text="{i18n>status}" labelFor="statusMultiCombo"/>
                                    <MultiComboBox
                                        id="statusMultiCombo"
                                        selectedKeys="{view>/filters/statusCodes}"
                                        width="100%">
                                        <core:Item key="O" text="{i18n>statusO}"/>
                                        <core:Item key="D" text="{i18n>statusD}"/>
                                        <core:Item key="P" text="{i18n>statusP}"/>
                                        <core:Item key="L" text="{i18n>statusL}"/>
                                        <core:Item key="C" text="{i18n>statusC}"/>
                                    </MultiComboBox>
                                </VBox>

                                <!-- <VBox class="dpmFilterItem dpmCheckItem">
                                    <Label text=" "/>
                                    <CheckBox
                                        text="{i18n>excludeCompleted}"
                                        selected="{view>/filters/excludeCompleted}"/>
                                </VBox> -->  <!--"입고완료 제외" 체크박스 사용 안 함-->
                            </FlexBox>

                            <FlexBox
                                wrap="Wrap"
                                renderType="Bare"
                                class="dpmFilterBar"
                                visible="{view>/advancedVisible}">
                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>bukrs}" labelFor="bukrsInput"/>
                                    <Input
                                        id="bukrsInput"
                                        value="{view>/filters/bukrs}"
                                        maxLength="4"
                                        showValueHelp="true"
                                        valueHelpRequest=".onValueHelpRequest">
                                        <customData>
                                            <!-- 회사코드 Search Help: ZCDS_D3_MM_0016_CDS -->
                                            <core:CustomData key="helpType" value="COMPANY"/>
                                        </customData>
                                    </Input>
                                </VBox>

                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>ebeln}" labelFor="ebelnInput"/>
                                    <Input
                                        id="ebelnInput"
                                        value="{view>/filters/ebeln}"
                                        maxLength="10"
                                        showValueHelp="true"
                                        valueHelpRequest=".onValueHelpRequest">
                                        <customData>
                                            <!-- PO Search Help: ZCDS_D3_MM_0015_CDS -->
                                            <core:CustomData key="helpType" value="PO"/>
                                        </customData>
                                    </Input>
                                </VBox>

                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>lifnr}" labelFor="lifnrInput"/>
                                    <Input
                                        id="lifnrInput"
                                        value="{view>/filters/lifnr}"
                                        maxLength="6"
                                        showValueHelp="true"
                                        valueHelpRequest=".onValueHelpRequest">
                                        <customData>
                                            <!-- 공급업체 Search Help: ZCDS_D3_MM_0013_CDS -->
                                            <core:CustomData key="helpType" value="VENDOR"/>
                                        </customData>
                                    </Input>
                                </VBox>

                                <VBox class="dpmFilterItemWide">
                                    <Label text="{i18n>name1}" labelFor="name1Input"/>
                                    <Input id="name1Input" value="{view>/filters/name1}"/>
                                </VBox>

                                <VBox class="dpmFilterItem">
                                    <Label text="{i18n>matnr}" labelFor="matnrInput"/>
                                    <Input
                                        id="matnrInput"
                                        value="{view>/filters/matnr}"
                                        maxLength="10"
                                        showValueHelp="true"
                                        valueHelpRequest=".onValueHelpRequest">
                                        <customData>
                                            <!--
                                                자재 Search Help: ZCDS_D3_MM_0014_CDS
                                                선택 시 자재코드(Matnr)와 자재명(Maktx)을 함께 세팅한다.
                                            -->
                                            <core:CustomData key="helpType" value="MATERIAL"/>
                                        </customData>
                                    </Input>
                                </VBox>

                                <VBox class="dpmFilterItemWide">
                                    <Label text="{i18n>maktx}" labelFor="maktxInput"/>
                                    <Input id="maktxInput" value="{view>/filters/maktx}"/>
                                </VBox>
                            </FlexBox>

                            <Toolbar class="dpmActionToolbar">
                                <ToolbarSpacer/>
                                <Button
                                    text="{= ${view>/advancedVisible} ? ${i18n>hideAdvancedSearch} : ${i18n>showAdvancedSearch} }"
                                    tooltip="{= ${view>/advancedVisible} ? ${i18n>hideAdvancedSearch} : ${i18n>showAdvancedSearch} }"
                                    type="Transparent"
                                    press=".onToggleAdvanced"/>
                                <Button
                                    text="{i18n>reset}"
                                    tooltip="{i18n>reset}"
                                    type="Transparent"
                                    press=".onReset"/>
                                <Button
                                    text="{i18n>search}"
                                    tooltip="{i18n>search}"
                                    type="Emphasized"
                                    press=".onSearch"/>
                            </Toolbar>
                        </VBox>
                    </content>
                </Panel>

                <!--
                    요약 영역.
                    - 왼쪽: 상태별 도넛 차트
                    - 오른쪽: KPI 카드 4개
                    KPI와 차트는 모두 "현재 검색조건 기준" 요약 정보이므로 한 영역에 묶어 세로 공간을 줄인다.
                -->
                <Panel class="dpmSection dpmSummaryPanel">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{i18n>summarySectionTitle}" level="H2"/>
                            <ObjectStatus
                                text="{i18n>kpiScopeText}"
                                icon="sap-icon://hint"
                                state="Information"
                                class="sapUiSmallMarginBegin"/>
                            <ToolbarSpacer/>
                            <Button
                                icon="sap-icon://clear-filter"
                                tooltip="{i18n>clearChartFilter}"
                                type="Transparent"
                                press=".onClearChartFilter"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <FlexBox wrap="Wrap" renderType="Bare" class="dpmSummaryLayout">
                            <VBox class="dpmSummaryChartArea">
                                <Title text="{i18n>statusChartTitle}" level="H3" class="dpmSummarySubTitle"/>
                                <!--
                                    상태 분포 차트.
                                    DelayedPoSet 결과를 클라이언트에서 O/D/P/L/C 상태별로 집계해 도넛 차트로 표시한다.
                                    차트 조각을 클릭하면 해당 상태가 메인 테이블 필터로 적용된다.
                                -->
                                <viz:VizFrame
                                    id="statusDistributionChart"
                                    width="100%"
                                    height="20rem"
                                    uiConfig="{applicationSet:'fiori'}"
                                    vizProperties="{
                                        title: { visible: false },
                                        tooltip: { visible: true },
                                        legend: { visible: true },
                                        plotArea: {
                                            colorPalette: ['#6a6d70', '#bb0000', '#0a6ed1', '#e9730c', '#107e3e'],
                                            drawingEffect: 'normal',
                                            dataLabel: {
                                                visible: true,
                                                type: 'value',
                                                hideWhenOverlap: true
                                            }
                                        }
                                    }"
                                    vizType="donut"
                                    selectData=".onStatusChartSelect"
                                    deselectData=".onStatusChartSelect">
                                    <viz:dataset>
                                        <viz.data:FlattenedDataset data="{chart>/statusDistribution}">
                                            <viz.data:dimensions>
                                                <viz.data:DimensionDefinition
                                                    name="Status"
                                                    value="{chart>StatusText}"/>
                                            </viz.data:dimensions>
                                            <viz.data:measures>
                                                <viz.data:MeasureDefinition
                                                    name="Count"
                                                    value="{chart>Count}"/>
                                            </viz.data:measures>
                                        </viz.data:FlattenedDataset>
                                    </viz:dataset>
                                    <viz:feeds>
                                        <viz.feeds:FeedItem
                                            uid="size"
                                            type="Measure"
                                            values="Count"/>
                                        <viz.feeds:FeedItem
                                            uid="color"
                                            type="Dimension"
                                            values="Status"/>
                                    </viz:feeds>
                                </viz:VizFrame>
                            </VBox>

                            <VBox class="dpmSummaryKpiArea">
                                <Title text="{i18n>kpiSectionTitle}" level="H3" class="dpmSummarySubTitle"/>
                                <FlexBox wrap="Wrap" renderType="Bare" class="dpmKpiBox dpmKpiBoxCompact">
                                    <GenericTile
                                        header="{i18n>kpiOpenPoItem}"
                                        class="dpmKpiTile dpmKpiTileCompact"
                                        press=".onKpiPress">
                                        <customData>
                                            <!--
                                                KPI 타일 클릭 시 Controller에서 어떤 빠른 필터를 적용할지 구분하는 값.
                                                CustomData는 화면에는 보이지 않고, press 이벤트에서 data("kpiAction")으로 읽는다.
                                            -->
                                            <core:CustomData key="kpiAction" value="OPEN_PO_ITEM"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{kpi>/OpenPoItemCnt}"
                                                icon="sap-icon://shipping-status"
                                                valueColor="Neutral"/>
                                        </TileContent>
                                    </GenericTile>

                                    <GenericTile
                                        header="{i18n>kpiDelayedItem}"
                                        class="dpmKpiTile dpmKpiTileCompact"
                                        press=".onKpiPress">
                                        <customData>
                                            <core:CustomData key="kpiAction" value="DELAYED_ITEM"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{kpi>/DelayedItemCnt}"
                                                icon="sap-icon://lateness"
                                                valueColor="Critical"/>
                                        </TileContent>
                                    </GenericTile>

                                    <GenericTile
                                        header="{i18n>kpiNoReceiptDelay}"
                                        class="dpmKpiTile dpmKpiTileCompact"
                                        press=".onKpiPress">
                                        <customData>
                                            <core:CustomData key="kpiAction" value="NO_RECEIPT_DELAY"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{kpi>/NoReceiptDelayCnt}"
                                                icon="sap-icon://error"
                                                valueColor="Error"/>
                                        </TileContent>
                                    </GenericTile>

                                    <GenericTile
                                        header="{i18n>kpiDelayedVendor}"
                                        class="dpmKpiTile dpmKpiTileCompact"
                                        press=".onKpiPress">
                                        <customData>
                                            <core:CustomData key="kpiAction" value="DELAYED_VENDOR"/>
                                        </customData>
                                        <TileContent>
                                            <NumericContent
                                                value="{kpi>/DelayedVendorCnt}"
                                                icon="sap-icon://supplier"
                                                valueColor="Neutral"/>
                                        </TileContent>
                                    </GenericTile>
                                </FlexBox>
                            </VBox>
                        </FlexBox>
                    </content>
                </Panel>

                <!--
                    메인 결과 테이블.
                    PO Item 1건이 한 행이며, 행 클릭 시 PoItemDetail.fragment.xml 상세 팝업을 연다.
                -->
                <Table
                    id="delayedPoTable"
                    width="100%"
                    contextualWidth="Auto"
                    items="{view>/items}"
                    busy="{view>/tableBusy}"
                    growing="true"
                    growingThreshold="20"
                    sticky="ColumnHeaders,HeaderToolbar"
                    mode="None">
                        <headerToolbar>
                            <OverflowToolbar>
                                <Title text="{i18n>resultTableTitle}" level="H2"/>
                                <Text
                                    text="{= '(' + ${view>/tableCount} + ')' }"
                                    class="dpmTableCountText"/>
                                <ToolbarSpacer/>
                                <!--
                                    테이블 상태/정렬 요약은 정보 표시용 텍스트다.
                                    사용자가 누르는 액션이 아니므로 아이콘을 빼고, 일반 텍스트 색상으로 차분하게 표시한다.
                                -->
                                <Text
                                    text="{view>/tableStatusSummary}"
                                    class="dpmTableSummaryText"/>
                                <Text
                                    text="{view>/tableSortGroupSummary}"
                                    class="dpmTableSummaryText"/>
                                <!-- 정렬/그룹 설정 Dialog를 여는 버튼이다. -->
                                <Button
                                    icon="sap-icon://sort"
                                    tooltip="{i18n>tableSettingsTitle}"
                                    type="Transparent"
                                    press=".onOpenTableSettings"/>
                                <!--
                                    테이블에 적용된 정렬/그룹만 초기화한다.
                                    검색조건과 조회 데이터는 유지하고, 사용자가 바꾼 테이블 표시 방식만 되돌린다.
                                -->
                                <Button
                                    icon="sap-icon://reset"
                                    tooltip="{i18n>tableSettingsReset}"
                                    type="Transparent"
                                    press=".onResetTableSettingsPress"/>
                                <!-- 현재 검색조건으로 테이블/KPI/차트를 다시 조회한다. -->
                                <Button
                                    icon="sap-icon://refresh"
                                    tooltip="{i18n>refresh}"
                                    type="Transparent"
                                    press=".onSearch"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <columns>
                            <!-- 기본 표시 컬럼. 숨김/표시 전환은 2차 개발에서 별도 기능으로 확장할 수 있다. -->
                            <Column width=""><Text text="{i18n>colStatus}"/></Column>
                            <Column width="" hAlign="End"><Text text="{i18n>colDelayDays}"/></Column>
                            <Column width=""><Text text="{i18n>colEindt}"/></Column>
                            <Column width=""><Text text="{i18n>colEbeln}"/></Column>
                            <Column width=""><Text text="{i18n>colEbelp}"/></Column>
                            <Column width=""><Text text="{i18n>colLifnr}"/></Column>
                            <Column
                                width=""
                                minScreenWidth="1000px"
                                demandPopin="false"
                                importance="Low">
                                <Text text="{i18n>colName1}"/>
                            </Column>
                            <Column width="8rem"><Text text="{i18n>colMatnr}"/></Column>
                            <Column
                                width=""
                                minScreenWidth="1000px"
                                demandPopin="false"
                                importance="Low">
                                <Text text="{i18n>colMaktx}"/>
                            </Column>
                            <Column width="" hAlign="End"><Text text="{i18n>colPoQty}"/></Column>
                            <Column width="" hAlign="End"><Text text="{i18n>colGrQty}"/></Column>
                            <Column width="" hAlign="End"><Text text="{i18n>colOpenQty}"/></Column>
                        </columns>
                        <items>
                            <ColumnListItem
                                type="Active"
                                press=".onItemPress"
                                highlight="{view>StatusState}"
                                highlightText="{view>StatusText}">
                                <cells>
                                    <!-- StatusState는 Gateway에서 UI5 ObjectStatus 값으로 내려온다. -->
                                    <ObjectStatus
                                        text="{view>StatusText}"
                                        state="{view>StatusState}"/>
                                    <Text
                                        text="{path: 'view>DelayDays', formatter: '.formatter.formatDelayDays'}"
                                        textAlign="End"/>
                                    <Text text="{path: 'view>Eindt', formatter: '.formatter.formatDate'}"/>
                                    <ObjectIdentifier title="{view>Ebeln}"/>
                                    <Text
                                        text="{path: 'view>Ebelp', formatter: '.formatter.formatItemNo'}"
                                        wrapping="false"/>
                                    <Text text="{view>Lifnr}"/>
                                    <Text text="{view>Name1}" wrapping="false"/>
                                    <Text text="{view>Matnr}"/>
                                    <Text text="{view>Maktx}" wrapping="false"/>
                                    <ObjectNumber
                                        number="{path: 'view>PoQty', formatter: '.formatter.formatQuantity'}"
                                        unit="{view>Meins}"/>
                                    <ObjectNumber
                                        number="{path: 'view>GrQty', formatter: '.formatter.formatQuantity'}"
                                        unit="{view>Meins}"/>
                                    <ObjectNumber
                                        number="{path: 'view>OpenQty', formatter: '.formatter.formatQuantity'}"
                                        unit="{view>Meins}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                </Table>
            </VBox>
        </content>
        <footer>
            <OverflowToolbar visible="{= ${messages>/count} > 0 }">
                <!--
                    조회조건 유효성 검증 메시지 버튼.
                    오류가 있을 때만 화면 좌측 하단 footer에 표시하고,
                    버튼을 누르면 MessagePopover로 누적 오류 목록을 보여준다.
                -->
                <Button
                    id="messagePopoverBtn"
                    icon="{messages>/buttonIcon}"
                    type="{messages>/buttonType}"
                    text="{messages>/buttonText}"
                    tooltip="{i18n>validationMessageButtonTooltip}"
                    visible="{= ${messages>/count} > 0 }"
                    press=".onMessagePopoverPress"
                    ariaHasPopup="Dialog"/>
                <ToolbarSpacer/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>
